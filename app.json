{
  "expo": {
    "name": "SolvyMed",
    "slug": "solvymed",
    "owner": "burrowsoftmobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "solvymed",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.burrowsoft.solvymed",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.burrowsoft.solvymed",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "versionCode": 5,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#208AEF"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#208AEF"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SolvyMed uses your photo library to let you upload a clinic logo for document templates."
        }
      ],
      "expo-asset",
      "expo-updates",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/51017924-6d1c-4686-b8b3-543d5a7ba76f"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "51017924-6d1c-4686-b8b3-543d5a7ba76f"
      }
    }
  }
}
